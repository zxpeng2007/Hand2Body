/data/
/checkpoints/
/runs/
*.npz
*.pt
*.ckpt
!assets/**/*.npz   # keep any small assets if added

# smpl model files (licensed — do not commit)
/models/smpl/
*.pkl

# os / editor
.DS_Store
.vscode/
.idea/
